# ── Required ──────────────────────────────────────────────────────────────────
# Copy this file to .env in apps/api/ and fill in your values

DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require"

JWT_SECRET="generate-a-strong-secret-here"
JWT_REFRESH_SECRET="generate-a-different-strong-secret"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# ── API Server ────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# Comma-separated list of allowed frontend origins
# For production: https://your-web.vercel.app,http://localhost:3000
CORS_ORIGIN=http://localhost:3000
