{
  "name": "team-task-manager",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "dev:api": "turbo run dev --filter=@ttm/api",
    "dev:web": "turbo run dev --filter=@ttm/web",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check",
    "db:generate": "pnpm --filter=@ttm/db generate",
    "db:migrate": "pnpm --filter=@ttm/db migrate:dev",
    "db:push": "pnpm --filter=@ttm/db db:push",
    "db:studio": "pnpm --filter=@ttm/db studio"
  },
  "devDependencies": {
    "turbo": "^2.1.3",
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=9.0.0"
  }
}
